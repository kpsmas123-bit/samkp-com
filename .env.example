# Copy to .env (gitignored) and fill in real values. NEVER commit .env.
# In GitHub Actions these live as repo secrets, not in this file.

CANVA_CLIENT_ID=OC-AZ9OTlvccTrS
CANVA_CLIENT_SECRET=cnvca_your_real_secret_here     # from your password manager
CANVA_DESIGN_ID=DAHO2N3OqNg

# Rotates on EVERY refresh. The pipeline persists the new value automatically
# (locally -> canva_tokens.json; in CI -> the CANVA_REFRESH_TOKEN repo secret).
CANVA_REFRESH_TOKEN=

# Only needed in CI, to write the rotated refresh token back to the repo secret.
# A PAT with permission to update Actions secrets (classic: repo scope; or a
# fine-grained token with Secrets: read/write on this repo). Store as secret GH_PAT.
# GH_PAT=
